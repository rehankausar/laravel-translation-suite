{
    "name": "rkwebsolution/translation-services",
    "description": "Multi-service translation package for Laravel. Supports Google, Azure, DeepL, Yandex, Amazon, and OpenAI through a unified manager, service provider, and facade",
    "version": "1.0.0",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Fastnet",
            "email": "websupport@fastnet.net.sa"
        }
    ],
    "require": {
        "php": "^8.1|^8.2|^8.3",
        "guzzlehttp/guzzle": "^7.0",
        "spatie/laravel-translatable": "^6.5"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "orchestra/testbench": "^8.0|^9.0"
    },
    "autoload": {
        "psr-4": {
            "Fastnet\\TranslationServices\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Fastnet\\TranslationServices\\TranslationServiceProvider"
            ],
            "aliases": {
                "Translator": "Fastnet\\TranslationServices\\Facades\\Translator"
            }
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
