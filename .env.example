# Translation Services Configuration

# Default service to use (google, deepl, azure, openai, yandex, amazon, ollama)
TRANSLATION_SERVICE=google

# Google Translate
GOOGLE_TRANSLATE_ENABLED=true
GOOGLE_TRANSLATE_API_KEY=

# DeepL
DEEPL_ENABLED=false
DEEPL_API_KEY=
DEEPL_PRO=false

# Azure Translator
AZURE_TRANSLATE_ENABLED=false
AZURE_TRANSLATE_API_KEY=
AZURE_TRANSLATE_REGION=global

# OpenAI
OPENAI_TRANSLATE_ENABLED=false
OPENAI_API_KEY=
OPENAI_MODEL=gpt-3.5-turbo

# Yandex Translate
YANDEX_TRANSLATE_ENABLED=false
YANDEX_TRANSLATE_API_KEY=
YANDEX_FOLDER_ID=

# Amazon Translate
AMAZON_TRANSLATE_ENABLED=false
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1

# Ollama (Local AI)
OLLAMA_TRANSLATE_ENABLED=false
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2:7b
OLLAMA_TIMEOUT=120

# Caching
TRANSLATION_CACHE_ENABLED=true
TRANSLATION_CACHE_TTL=86400

# Logging
TRANSLATION_LOGGING_ENABLED=true
TRANSLATION_LOG_CHANNEL=stack
